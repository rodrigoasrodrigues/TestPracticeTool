SECRET_KEY=your-secret-key-here
# Option 1: full SQLAlchemy URL
DATABASE_URL=
# Option 2: separate database vars (recommended when the password has special characters)
DB_DRIVER=mysql+pymysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=testpracticetool
DB_USER=root
DB_PASSWORD=password
# Set to 'true' only in development, never in production
FLASK_DEBUG=false
# Optional: when set, images are stored in this S3 prefix instead of local static/uploads
IMAGE_S3_PATH=s3://your-bucket/testpracticetool/uploads
# Optional: dedicated credentials for the application to access S3 (separate from CI/CD credentials)
APP_AWS_REGION=us-east-1
APP_AWS_ACCESS_KEY_ID=
APP_AWS_SECRET_ACCESS_KEY=
APP_AWS_SESSION_TOKEN=
AWS_S3_ENDPOINT_URL=
AWS_REGION=us-east-1
